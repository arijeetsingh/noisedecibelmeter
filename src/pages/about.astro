---
import Layout from '../layouts/Layout.astro';

const title = 'About — Noise Decibel Meter';
const description = 'Learn about Noise Decibel Meter — a free, privacy-first browser tool that measures real-time sound levels with no installation, no account, and no data collection.';
const canonicalUrl = 'https://noisedecibelmeter.com/about';
---

<style>
  html[data-dark] .page-title { color: #f2f2f2 !important; }
  html[data-dark] .page-body  { color: #b0b0b0 !important; }
  html[data-dark] .page-h2   { color: #f2f2f2 !important; }
  html[data-dark] .feature-card { background: #1a1a1a !important; border-color: #272727 !important; }
  html[data-dark] .feature-icon { background: #111 !important; border-color: #2a2a2a !important; }
  html[data-dark] .feature-title { color: #f2f2f2 !important; }
  html[data-dark] .feature-desc { color: #b0b0b0 !important; }
</style>

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <main style="max-width:720px;margin:0 auto;padding:64px 24px 96px;">

    <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 16px;">About</p>
    <h1 class="page-title" style="font-size:40px;font-weight:600;color:#171717;letter-spacing:-1.8px;line-height:1.1;margin:0 0 20px;">
      A simple tool that does one thing well.
    </h1>
    <p class="page-body" style="font-size:17px;color:#4d4d4d;line-height:1.75;margin:0 0 48px;">
      Noise Decibel Meter is a free, browser-based sound level meter built for anyone who needs a quick, accurate decibel reading — without installing an app, creating an account, or giving away personal data.
    </p>

    <h2 class="page-h2" style="font-size:22px;font-weight:600;color:#171717;letter-spacing:-0.6px;margin:0 0 20px;">Why we built it</h2>
    <p class="page-body" style="font-size:16px;color:#4d4d4d;line-height:1.75;margin:0 0 20px;">
      Existing decibel meter apps often require installation, request unnecessary permissions (contacts, location, camera), or are buried under ads. We wanted something different: open your browser, click one button, and get a reading. No friction. No tracking.
    </p>
    <p class="page-body" style="font-size:16px;color:#4d4d4d;line-height:1.75;margin:0 0 48px;">
      The tool uses your browser's Web Audio API to process microphone data entirely on your device. No audio is ever transmitted to a server — your measurements stay completely private.
    </p>

    <h2 class="page-h2" style="font-size:22px;font-weight:600;color:#171717;letter-spacing:-0.6px;margin:0 0 20px;">What it does</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:48px;">
      {[
        { icon: '📊', title: 'Real-time dB readings', desc: 'Live gauge and numeric display updated every animation frame.' },
        { icon: '⚖️', title: 'dBA & dBC weighting', desc: 'Switch between A-weighted (human hearing) and C-weighted (low-frequency) modes.' },
        { icon: '📈', title: '60-second history', desc: 'Visual waveform graph tracks noise levels over the last minute.' },
        { icon: '📁', title: 'CSV export', desc: 'Download a timestamped log of every reading for documentation.' },
        { icon: '🌙', title: 'Dark mode', desc: 'Full dark theme that respects your system preference.' },
        { icon: '🔒', title: 'Privacy-first', desc: 'All processing is local. No server, no storage, no analytics on audio.' },
      ].map(f => (
        <div class="feature-card" style="background:#fff;border:1px solid #ebebeb;border-radius:12px;padding:20px;">
          <div class="feature-icon" style="width:36px;height:36px;border-radius:8px;background:#fafafa;border:1px solid #ebebeb;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:12px;">{f.icon}</div>
          <div class="feature-title" style="font-size:14px;font-weight:600;color:#171717;margin-bottom:6px;">{f.title}</div>
          <div class="feature-desc" style="font-size:13px;color:#4d4d4d;line-height:1.6;">{f.desc}</div>
        </div>
      ))}
    </div>

    <h2 class="page-h2" style="font-size:22px;font-weight:600;color:#171717;letter-spacing:-0.6px;margin:0 0 12px;">Accuracy</h2>
    <p class="page-body" style="font-size:16px;color:#4d4d4d;line-height:1.75;margin:0 0 12px;">
      Browser-based decibel meters are accurate enough for everyday use — typically within ±2–3 dB — making them excellent for trend monitoring, noise complaints, and general awareness. Accuracy depends on your device's microphone quality.
    </p>
    <p class="page-body" style="font-size:16px;color:#4d4d4d;line-height:1.75;margin:0;">
      For legally compliant occupational safety assessments (OSHA, ISO 61672), a certified hardware sound level meter is required. Phone microphones are not factory-calibrated to those standards.
    </p>

  </main>
</Layout>
