---
import Layout from '../layouts/Layout.astro';

const title = 'Contact — Noise Decibel Meter';
const description = 'Get in touch with the Noise Decibel Meter team. Questions, feedback, or bug reports — we read every message.';
const canonicalUrl = 'https://noisedecibelmeter.com/contact';
---

<style>
  html[data-dark] .page-title  { color: #f2f2f2 !important; }
  html[data-dark] .page-body  { color: #888 !important; }
  html[data-dark] .contact-card { background: #1a1a1a !important; border-color: #272727 !important; }
  html[data-dark] .contact-label { color: #555 !important; }
  html[data-dark] .contact-value { color: #f2f2f2 !important; }
  html[data-dark] .contact-note  { color: #555 !important; }
  html[data-dark] .topic-card { background: #1a1a1a !important; border-color: #272727 !important; }
  html[data-dark] .topic-title { color: #f2f2f2 !important; }
  html[data-dark] .topic-desc { color: #888 !important; }
  html[data-dark] .email-link { color: #f2f2f2 !important; }
</style>

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <main style="max-width:720px;margin:0 auto;padding:64px 24px 96px;">

    <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 16px;">Contact</p>
    <h1 class="page-title" style="font-size:40px;font-weight:600;color:#171717;letter-spacing:-1.8px;line-height:1.1;margin:0 0 20px;">
      Get in touch.
    </h1>
    <p class="page-body" style="font-size:17px;color:#4d4d4d;line-height:1.75;margin:0 0 48px;">
      We read every message. Whether it's a bug report, a feature idea, or a question about how the tool works — drop us an email.
    </p>

    <!-- Email card -->
    <div class="contact-card" style="background:#fff;border:1px solid #ebebeb;border-radius:16px;padding:32px;margin-bottom:48px;">
      <p class="contact-label" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 8px;">Email</p>
      <a class="contact-value email-link" href="mailto:hello@noisedecibelmeter.com" style="font-size:22px;font-weight:600;color:#171717;letter-spacing:-0.5px;text-decoration:none;">
        hello@noisedecibelmeter.com
      </a>
      <p class="contact-note" style="font-size:14px;color:#888;margin:12px 0 0;">We aim to reply within 2 business days.</p>
    </div>

    <!-- Topic shortcuts -->
    <p class="page-body" style="font-size:14px;color:#888;font-weight:500;margin:0 0 16px;">Common topics</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
      {[
        { icon: '🐛', title: 'Bug report', desc: 'Something isn\'t working as expected?' },
        { icon: '💡', title: 'Feature request', desc: 'Have an idea to make the tool better?' },
        { icon: '🔒', title: 'Privacy question', desc: 'Questions about how your data is handled?' },
        { icon: '🤝', title: 'Partnership', desc: 'Interested in working together?' },
      ].map(t => (
        <a href={`mailto:hello@noisedecibelmeter.com?subject=${encodeURIComponent(t.title)}`}
           class="topic-card"
           style="background:#fff;border:1px solid #ebebeb;border-radius:12px;padding:20px;text-decoration:none;display:block;transition:border-color 0.15s;">
          <div style="font-size:20px;margin-bottom:8px;">{t.icon}</div>
          <div class="topic-title" style="font-size:14px;font-weight:600;color:#171717;margin-bottom:4px;">{t.title}</div>
          <div class="topic-desc" style="font-size:13px;color:#4d4d4d;line-height:1.5;">{t.desc}</div>
        </a>
      ))}
    </div>

  </main>
</Layout>
