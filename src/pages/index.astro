---
import Layout from '../layouts/Layout.astro';
---

<style>
  @media (max-width: 600px) {
    .legend-grid { grid-template-columns: 1fr 1fr !important; }
    .hero-h1 { font-size: 36px !important; letter-spacing: -1.5px !important; }
    .btn-row { flex-direction: column !important; align-items: stretch !important; }
    .btn-row button { width: 100% !important; }
  }
  #btn-start:hover { background: #333 !important; }
  #btn-stop:hover:not(:disabled), #btn-export:hover:not(:disabled) { border-color: #a1a1a1 !important; }
</style>

<Layout>
  <!-- Nav -->
  <nav style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,0.85);backdrop-filter:blur(12px);border-bottom:1px solid #ebebeb;">
    <div style="max-width:960px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:8px;">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
          <circle cx="10" cy="10" r="8" stroke="#171717" stroke-width="1.5"/>
          <circle cx="10" cy="10" r="3" fill="#171717"/>
          <path d="M10 4v2M10 14v2M4 10h2M14 10h2" stroke="#171717" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span style="font-size:14px;font-weight:600;color:#171717;letter-spacing:-0.3px;">NoiseDecibel</span>
      </div>
      <span id="nav-live" style="display:none;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;">
        <span style="width:6px;height:6px;border-radius:50%;background:#50e3c2;display:inline-block;" id="live-dot"></span>
        LIVE
      </span>
    </div>
  </nav>

  <main style="max-width:960px;margin:0 auto;padding:48px 24px 80px;">

    <!-- Hero -->
    <div style="text-align:center;margin-bottom:48px;">
      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 16px;">Free online sound level meter</p>
      <h1 class="hero-h1" style="font-size:48px;font-weight:600;color:#171717;letter-spacing:-2.4px;line-height:1.05;margin:0 0 16px;">
        Real-time noise<br/>decibel meter.
      </h1>
      <p style="font-size:18px;color:#4d4d4d;line-height:1.6;margin:0;max-width:400px;display:inline-block;">
        Measure environmental noise instantly from your browser. No installs, no accounts.
      </p>
    </div>

    <!-- Main card -->
    <div style="background:#fff;border-radius:16px;border:1px solid #ebebeb;box-shadow:0 2px 2px rgba(0,0,0,0.04),0 8px 16px -4px rgba(0,0,0,0.06);overflow:hidden;margin-bottom:16px;">

      <!-- Classification badge -->
      <div style="padding:24px 32px 0;display:flex;justify-content:center;">
        <div id="classification-badge" style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:100px;background:#fafafa;border:1px solid #ebebeb;font-size:13px;font-weight:500;color:#888;transition:all 0.4s;">
          <span id="badge-dot" style="width:8px;height:8px;border-radius:50%;background:#ddd;flex-shrink:0;transition:background 0.4s;"></span>
          <span id="badge-label">Grant microphone access to begin</span>
        </div>
      </div>

      <!-- Gauge + reading -->
      <div style="display:flex;flex-direction:column;align-items:center;padding:32px 32px 24px;">

        <!-- SVG Gauge -->
        <div style="width:280px;height:148px;position:relative;margin-bottom:24px;">
          <svg viewBox="0 0 280 148" width="280" height="148">
            <!-- Background track -->
            <path d="M 20 140 A 120 120 0 0 1 260 140" fill="none" stroke="#ebebeb" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone arcs -->
            <path id="arc-silent"   d="M 20 140 A 120 120 0 0 1 260 140" fill="none" stroke="#50e3c2" stroke-width="14" stroke-linecap="butt" stroke-dasharray="0 377"/>
            <path id="arc-moderate" d="M 20 140 A 120 120 0 0 1 260 140" fill="none" stroke="#f5a623" stroke-width="14" stroke-linecap="butt" stroke-dasharray="0 377"/>
            <path id="arc-loud"     d="M 20 140 A 120 120 0 0 1 260 140" fill="none" stroke="#ff4d4d" stroke-width="14" stroke-linecap="butt" stroke-dasharray="0 377"/>
            <path id="arc-danger"   d="M 20 140 A 120 120 0 0 1 260 140" fill="none" stroke="#c50000" stroke-width="14" stroke-linecap="butt" stroke-dasharray="0 377"/>
            <!-- Scale ticks -->
            <text x="16" y="148" fill="#aaa" font-size="9" font-family="JetBrains Mono,monospace" text-anchor="middle">0</text>
            <text x="140" y="16" fill="#aaa" font-size="9" font-family="JetBrains Mono,monospace" text-anchor="middle">65</text>
            <text x="264" y="148" fill="#aaa" font-size="9" font-family="JetBrains Mono,monospace" text-anchor="middle">130</text>
            <!-- Needle -->
            <line id="gauge-needle" x1="140" y1="140" x2="140" y2="32" stroke="#171717" stroke-width="2" stroke-linecap="round" transform="rotate(-90 140 140)"/>
            <circle cx="140" cy="140" r="5" fill="#171717"/>
          </svg>
        </div>

        <!-- dB number -->
        <div style="text-align:center;margin-bottom:20px;">
          <div style="display:flex;align-items:flex-end;justify-content:center;gap:8px;line-height:1;">
            <span id="db-value" style="font-family:'JetBrains Mono',monospace;font-size:72px;font-weight:600;color:#171717;letter-spacing:-3px;line-height:1;">--</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:22px;color:#888;margin-bottom:10px;">dB</span>
          </div>
          <!-- Weighting toggle -->
          <div style="display:flex;justify-content:center;gap:4px;margin-top:12px;">
            <button id="weight-a" onclick="setWeighting('A')" style="padding:4px 12px;border-radius:100px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;background:#171717;color:#fff;border:none;cursor:pointer;">dBA</button>
            <button id="weight-c" onclick="setWeighting('C')" style="padding:4px 12px;border-radius:100px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;background:#fafafa;color:#888;border:1px solid #ebebeb;cursor:pointer;">dBC</button>
          </div>
        </div>

        <!-- Stats -->
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;width:100%;max-width:360px;margin-bottom:28px;">
          <div style="background:#fafafa;border-radius:10px;border:1px solid #ebebeb;padding:12px;text-align:center;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#888;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Min</div>
            <div id="stat-min" style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:600;color:#171717;">--</div>
          </div>
          <div style="background:#fafafa;border-radius:10px;border:1px solid #ebebeb;padding:12px;text-align:center;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#888;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Avg</div>
            <div id="stat-avg" style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:600;color:#171717;">--</div>
          </div>
          <div style="background:#fafafa;border-radius:10px;border:1px solid #ebebeb;padding:12px;text-align:center;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#888;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Max</div>
            <div id="stat-max" style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:600;color:#171717;">--</div>
          </div>
        </div>

        <!-- Buttons -->
        <div class="btn-row" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center;">
          <button id="btn-start" onclick="startMeasuring()"
            style="padding:0 24px;height:44px;border-radius:100px;background:#171717;color:#fff;font-size:14px;font-weight:500;border:none;cursor:pointer;letter-spacing:-0.2px;">
            Start Measuring
          </button>
          <button id="btn-stop" onclick="stopMeasuring()" disabled
            style="padding:0 24px;height:44px;border-radius:100px;background:#fff;color:#171717;font-size:14px;font-weight:500;border:1px solid #ebebeb;cursor:pointer;opacity:0.4;">
            Stop
          </button>
          <button id="btn-export" onclick="exportCsv()" disabled
            style="padding:0 24px;height:44px;border-radius:100px;background:#fff;color:#171717;font-size:14px;font-weight:500;border:1px solid #ebebeb;cursor:pointer;opacity:0.4;">
            Export CSV
          </button>
        </div>
      </div>

      <!-- History graph -->
      <div style="border-top:1px solid #ebebeb;padding:24px 32px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#888;text-transform:uppercase;letter-spacing:0.08em;">60s history</span>
          <span id="duration-label" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;">0:00</span>
        </div>
        <canvas id="history-canvas" height="72" style="width:100%;display:block;border-radius:8px;background:#fafafa;border:1px solid #ebebeb;"></canvas>
        <div style="display:flex;justify-content:space-between;margin-top:4px;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#aaa;">0 dB</span>
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#aaa;">65 dB</span>
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#aaa;">130 dB</span>
        </div>
      </div>
    </div>

    <!-- Legend -->
    <div class="legend-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:48px;">
      <div style="background:#fff;border-radius:10px;border:1px solid #ebebeb;padding:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#50e3c2;flex-shrink:0;"></span>
          <span style="font-size:13px;font-weight:500;color:#171717;">Silent</span>
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;margin-bottom:4px;">0–40 dB</div>
        <div style="font-size:12px;color:#4d4d4d;">Whisper, rustling leaves</div>
      </div>
      <div style="background:#fff;border-radius:10px;border:1px solid #ebebeb;padding:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#f5a623;flex-shrink:0;"></span>
          <span style="font-size:13px;font-weight:500;color:#171717;">Moderate</span>
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;margin-bottom:4px;">40–70 dB</div>
        <div style="font-size:12px;color:#4d4d4d;">Conversation, office</div>
      </div>
      <div style="background:#fff;border-radius:10px;border:1px solid #ebebeb;padding:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#ff4d4d;flex-shrink:0;"></span>
          <span style="font-size:13px;font-weight:500;color:#171717;">Loud</span>
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;margin-bottom:4px;">70–90 dB</div>
        <div style="font-size:12px;color:#4d4d4d;">Traffic, vacuum cleaner</div>
      </div>
      <div style="background:#fff;border-radius:10px;border:1px solid #ebebeb;padding:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#c50000;flex-shrink:0;"></span>
          <span style="font-size:13px;font-weight:500;color:#171717;">Danger</span>
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;margin-bottom:4px;">90+ dB</div>
        <div style="font-size:12px;color:#4d4d4d;">Construction, concerts</div>
      </div>
    </div>

  </main>

  <!-- Footer -->
  <footer style="border-top:1px solid #ebebeb;background:#fff;">
    <div style="max-width:960px;margin:0 auto;padding:28px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="font-size:14px;font-weight:600;color:#171717;">NoiseDecibel</span>
        <span style="font-size:14px;color:#888;">— free online sound level meter</span>
      </div>
      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;margin:0;">Audio processed locally. Never sent to any server.</p>
    </div>
  </footer>
</Layout>

<script is:inline>
// ── State ──────────────────────────────────────────────────────────────────
var audioCtx = null;
var analyser = null;
var stream = null;
var animFrame = null;
var weighting = 'A';
var samples = [];
var sessionStart = 0;
var durationInterval = null;

var HISTORY_SECONDS = 60;
var DB_MAX = 130;
var ARC_TOTAL = Math.PI * 120; // ~376.99

// ── DOM refs ───────────────────────────────────────────────────────────────
var btnStart   = document.getElementById('btn-start');
var btnStop    = document.getElementById('btn-stop');
var btnExport  = document.getElementById('btn-export');
var dbValue    = document.getElementById('db-value');
var statMin    = document.getElementById('stat-min');
var statAvg    = document.getElementById('stat-avg');
var statMax    = document.getElementById('stat-max');
var badgeLabel = document.getElementById('badge-label');
var badgeDot   = document.getElementById('badge-dot');
var badge      = document.getElementById('classification-badge');
var needle     = document.getElementById('gauge-needle');
var navLive    = document.getElementById('nav-live');
var canvas     = document.getElementById('history-canvas');
var durLabel   = document.getElementById('duration-label');

var arcSilent   = document.getElementById('arc-silent');
var arcModerate = document.getElementById('arc-moderate');
var arcLoud     = document.getElementById('arc-loud');
var arcDanger   = document.getElementById('arc-danger');

// ── Classifications ────────────────────────────────────────────────────────
var CLASSES = [
  { max:20,  label:'Near silence',       dot:'#50e3c2', bg:'#fafafa',  border:'#ddd',    text:'#888' },
  { max:40,  label:'Very quiet',         dot:'#50e3c2', bg:'#fafafa',  border:'#ddd',    text:'#888' },
  { max:55,  label:'Library quiet',      dot:'#50e3c2', bg:'#e6faf6',  border:'#50e3c2', text:'#29bc9b' },
  { max:65,  label:'Normal conversation',dot:'#50e3c2', bg:'#e6faf6',  border:'#50e3c2', text:'#29bc9b' },
  { max:70,  label:'Busy office',        dot:'#f5a623', bg:'#fff8ec',  border:'#f5a623', text:'#ab570a' },
  { max:75,  label:'Vacuum cleaner loud',dot:'#f5a623', bg:'#fff8ec',  border:'#f5a623', text:'#ab570a' },
  { max:85,  label:'Busy traffic noise', dot:'#ff4d4d', bg:'#fff0f0',  border:'#ff4d4d', text:'#c50000' },
  { max:95,  label:'Hearing damage risk',dot:'#ff4d4d', bg:'#fff0f0',  border:'#ff4d4d', text:'#c50000' },
  { max:110, label:'Construction zone',  dot:'#c50000', bg:'#ffe5e5',  border:'#c50000', text:'#8b0000' },
  { max:130, label:'Dangerously loud',   dot:'#c50000', bg:'#ffe5e5',  border:'#c50000', text:'#8b0000' },
];

function classify(db) {
  for (var i = 0; i < CLASSES.length; i++) {
    if (db < CLASSES[i].max) return CLASSES[i];
  }
  return CLASSES[CLASSES.length - 1];
}

// ── Gauge ──────────────────────────────────────────────────────────────────
function updateGauge(db) {
  var fraction = Math.max(0, Math.min(1, db / DB_MAX));
  var angle = -90 + fraction * 180;
  needle.setAttribute('transform', 'rotate(' + angle + ' 140 140)');

  var zones = [
    { el: arcSilent,   start: 0,  end: 40  },
    { el: arcModerate, start: 40, end: 70  },
    { el: arcLoud,     start: 70, end: 90  },
    { el: arcDanger,   start: 90, end: 130 },
  ];

  for (var i = 0; i < zones.length; i++) {
    var z = zones[i];
    var clampedDb = Math.max(0, Math.min(DB_MAX, db));
    if (clampedDb <= z.start) {
      z.el.setAttribute('stroke-dasharray', '0 ' + ARC_TOTAL);
      continue;
    }
    var startPct = z.start / DB_MAX;
    var endPct   = Math.min(clampedDb, z.end) / DB_MAX;
    var drawn    = (endPct - startPct) * ARC_TOTAL;
    z.el.setAttribute('stroke-dasharray',  drawn + ' ' + ARC_TOTAL);
    z.el.setAttribute('stroke-dashoffset', (ARC_TOTAL * (1 - startPct) - drawn).toString());
  }
}

// ── History canvas ─────────────────────────────────────────────────────────
function drawHistory() {
  var ctx = canvas.getContext('2d');
  var rect = canvas.getBoundingClientRect();
  if (canvas.width !== Math.round(rect.width)) canvas.width = Math.round(rect.width);
  var W = canvas.width, H = canvas.height;

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#fafafa';
  ctx.fillRect(0, 0, W, H);

  // Zone bands
  var bands = [
    {min:0,  max:40,  c:'rgba(80,227,194,0.07)'},
    {min:40, max:70,  c:'rgba(245,166,35,0.07)'},
    {min:70, max:90,  c:'rgba(255,77,77,0.07)'},
    {min:90, max:130, c:'rgba(197,0,0,0.07)'},
  ];
  for (var i = 0; i < bands.length; i++) {
    var b = bands[i];
    ctx.fillStyle = b.c;
    ctx.fillRect(0, H - (b.max / DB_MAX) * H, W, ((b.max - b.min) / DB_MAX) * H);
  }

  // 65 dB guide line
  ctx.strokeStyle = '#e0e0e0';
  ctx.lineWidth = 1;
  ctx.setLineDash([3, 3]);
  ctx.beginPath();
  ctx.moveTo(0, H - (65 / DB_MAX) * H);
  ctx.lineTo(W, H - (65 / DB_MAX) * H);
  ctx.stroke();
  ctx.setLineDash([]);

  if (samples.length < 2) return;

  var now = Date.now();
  var windowMs = HISTORY_SECONDS * 1000;
  var visible = samples.filter(function(s) { return (now - s.time) <= windowMs; });
  if (visible.length < 2) return;

  // Fill
  ctx.beginPath();
  var x0 = W - ((now - visible[0].time) / windowMs) * W;
  var y0 = H - (visible[0].db / DB_MAX) * H;
  ctx.moveTo(x0, H);
  ctx.lineTo(x0, y0);
  for (var i = 1; i < visible.length; i++) {
    ctx.lineTo(W - ((now - visible[i].time) / windowMs) * W, H - (visible[i].db / DB_MAX) * H);
  }
  ctx.lineTo(W, H);
  ctx.closePath();
  var grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, 'rgba(23,23,23,0.12)');
  grad.addColorStop(1, 'rgba(23,23,23,0.01)');
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  ctx.moveTo(W - ((now - visible[0].time) / windowMs) * W, H - (visible[0].db / DB_MAX) * H);
  for (var i = 1; i < visible.length; i++) {
    ctx.lineTo(W - ((now - visible[i].time) / windowMs) * W, H - (visible[i].db / DB_MAX) * H);
  }
  ctx.strokeStyle = '#171717';
  ctx.lineWidth = 1.5;
  ctx.stroke();
}

// ── Audio ──────────────────────────────────────────────────────────────────
function getRms(buf) {
  var sum = 0;
  for (var i = 0; i < buf.length; i++) sum += buf[i] * buf[i];
  return Math.sqrt(sum / buf.length);
}

function rmsToDb(rms) {
  if (rms < 1e-10) return 0;
  var raw = 20 * Math.log10(rms) + 90;
  return Math.max(0, Math.min(130, raw + (weighting === 'A' ? 2 : 0)));
}

function tick() {
  if (!analyser) return;
  var buf = new Float32Array(analyser.fftSize);
  analyser.getFloatTimeDomainData(buf);
  var db = rmsToDb(getRms(buf));

  dbValue.textContent = db.toFixed(1);
  updateGauge(db);

  var cls = classify(db);
  badgeLabel.textContent = cls.label;
  badgeDot.style.background = cls.dot;
  badge.style.background = cls.bg;
  badge.style.borderColor = cls.border;
  badge.style.color = cls.text;

  var now = Date.now();
  samples.push({ db: db, time: now });
  var cutoff = now - HISTORY_SECONDS * 1000;
  samples = samples.filter(function(s) { return s.time >= cutoff; });

  if (samples.length) {
    var dbs = samples.map(function(s) { return s.db; });
    statMin.textContent = Math.min.apply(null, dbs).toFixed(1);
    statMax.textContent = Math.max.apply(null, dbs).toFixed(1);
    statAvg.textContent = (dbs.reduce(function(a, b) { return a + b; }, 0) / dbs.length).toFixed(1);
  }

  drawHistory();
  animFrame = requestAnimationFrame(tick);
}

// ── Controls ───────────────────────────────────────────────────────────────
function startMeasuring() {
  navigator.mediaDevices.getUserMedia({ audio: true, video: false })
    .then(function(s) {
      stream = s;
      audioCtx = new AudioContext();
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 2048;
      analyser.smoothingTimeConstant = 0.3;
      audioCtx.createMediaStreamSource(stream).connect(analyser);

      sessionStart = Date.now();
      samples = [];

      btnStart.disabled = true;
      btnStart.style.opacity = '0.4';
      btnStop.disabled = false;
      btnStop.style.opacity = '1';
      btnExport.disabled = false;
      btnExport.style.opacity = '1';
      navLive.style.display = 'flex';

      durationInterval = setInterval(function() {
        var elapsed = Math.floor((Date.now() - sessionStart) / 1000);
        var m = Math.floor(elapsed / 60);
        var s = elapsed % 60;
        durLabel.textContent = m + ':' + (s < 10 ? '0' : '') + s;
      }, 1000);

      // Pulse live dot
      var dot = document.getElementById('live-dot');
      setInterval(function() {
        dot.style.opacity = dot.style.opacity === '0' ? '1' : '0';
      }, 800);

      tick();
    })
    .catch(function() {
      badgeLabel.textContent = 'Microphone access denied — check browser permissions';
      badge.style.background = '#fff0f0';
      badge.style.borderColor = '#ff4d4d';
      badge.style.color = '#c50000';
      badgeDot.style.background = '#ff4d4d';
    });
}

function stopMeasuring() {
  if (animFrame) cancelAnimationFrame(animFrame);
  if (durationInterval) clearInterval(durationInterval);
  if (stream) stream.getTracks().forEach(function(t) { t.stop(); });
  if (audioCtx) audioCtx.close();
  stream = null; audioCtx = null; analyser = null;

  btnStart.disabled = false;
  btnStart.style.opacity = '1';
  btnStop.disabled = true;
  btnStop.style.opacity = '0.4';
  navLive.style.display = 'none';

  badgeLabel.textContent = 'Measurement stopped';
  badge.style.background = '#fafafa';
  badge.style.borderColor = '#ebebeb';
  badge.style.color = '#888';
  badgeDot.style.background = '#ddd';
}

function exportCsv() {
  var lines = ['time_ms,db_value'];
  for (var i = 0; i < samples.length; i++) {
    lines.push(samples[i].time + ',' + samples[i].db.toFixed(2));
  }
  var blob = new Blob([lines.join('\n')], { type: 'text/csv' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'noise-session-' + new Date().toISOString().slice(0,19).replace(/:/g,'-') + '.csv';
  a.click();
  URL.revokeObjectURL(url);
}

function setWeighting(w) {
  weighting = w;
  document.getElementById('weight-a').style.background = w === 'A' ? '#171717' : '#fafafa';
  document.getElementById('weight-a').style.color = w === 'A' ? '#fff' : '#888';
  document.getElementById('weight-a').style.border = w === 'A' ? 'none' : '1px solid #ebebeb';
  document.getElementById('weight-c').style.background = w === 'C' ? '#171717' : '#fafafa';
  document.getElementById('weight-c').style.color = w === 'C' ? '#fff' : '#888';
  document.getElementById('weight-c').style.border = w === 'C' ? 'none' : '1px solid #ebebeb';
}

// init
updateGauge(0);
</script>
