---
import Layout from '../layouts/Layout.astro';
import type { Translations } from '../i18n/en';

interface Props { t: Translations; lang?: string; }
const { t, lang = 'en' } = Astro.props;
const pr = t.privacy;
const prefix = lang === 'en' ? '' : `/${lang}`;
const canonicalUrl = lang === 'en'
  ? 'https://noisedecibelmeter.com/privacy-policy/'
  : `https://noisedecibelmeter.com/${lang}/privacy-policy/`;
---

<style>
  html[data-dark] .page-title    { color: #f2f2f2 !important; }
  html[data-dark] .page-date     { color: #555 !important; }
  html[data-dark] .page-h2       { color: #f2f2f2 !important; }
  html[data-dark] .page-body     { color: #b0b0b0 !important; }
  html[data-dark] .highlight-box { background: #1a1a1a !important; border-color: #272727 !important; }
  html[data-dark] .highlight-text { color: #f2f2f2 !important; }
  html[data-dark] code { background: #222 !important; color: #d0d0d0 !important; }
</style>

<Layout title={pr.title} description={pr.description} canonicalUrl={canonicalUrl} lang={lang} pagePath="privacy-policy" ogLocale={t.ogLocale}>
  <main style="max-width:720px;margin:0 auto;padding:64px 24px 96px;">

    <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 16px;">{pr.label}</p>
    <h1 class="page-title" style="font-size:40px;font-weight:600;color:#171717;letter-spacing:-1.8px;line-height:1.1;margin:0 0 12px;">{pr.h1}</h1>
    <p class="page-date" style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#888;margin:0 0 48px;">{pr.updated}</p>

    <div class="highlight-box" style="background:#fafafa;border:1px solid #ebebeb;border-radius:12px;padding:24px;margin-bottom:48px;">
      <p class="highlight-text" style="font-size:16px;font-weight:600;color:#171717;margin:0 0 8px;">{pr.tldrTitle}</p>
      <p class="page-body" style="font-size:15px;color:#4d4d4d;line-height:1.7;margin:0;">{pr.tldrBody}</p>
    </div>

    {pr.sections.map((section, i) => (
      <div>
        <h2 class="page-h2" style="font-size:20px;font-weight:600;color:#171717;letter-spacing:-0.5px;margin:0 0 12px;">{section.h2}</h2>
        {i === pr.sections.length - 1 ? (
          <p class="page-body" style="font-size:16px;color:#4d4d4d;line-height:1.75;margin:0 0 32px;">
            {section.body} <a href={`${prefix}/contact/`} style="color:#171717;text-decoration:underline;text-underline-offset:3px;">{pr.contactLink}</a> {pr.contactSuffix}
          </p>
        ) : (
          <p class="page-body" style="font-size:16px;color:#4d4d4d;line-height:1.75;margin:0 0 32px;">{section.body}</p>
        )}
      </div>
    ))}

  </main>
</Layout>
