---
import '../styles/global.css';
import { getTranslations, localePath } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonicalUrl?: string;
  ogImage?: string;
  lang?: string;
  pagePath?: string;
  ogLocale?: string;
}

const {
  title = 'Decibel Meter Online — Free Real-Time Sound Level Meter',
  description = 'Use our free online decibel meter to measure real-time sound levels directly in your browser. No download needed.',
  keywords = 'decibel meter, decibel meter online, online decibel meter, sound decibel meter, decibel meter free, free decibel meter, decibel meter online free, best decibel meter, decibel meter chart, professional decibel meter, noise decibel meter, outdoor decibel meter',
  canonicalUrl = 'https://noisedecibelmeter.com/',
  ogImage = 'https://noisedecibelmeter.com/og-image.png',
  lang = 'en',
  pagePath = '',
  ogLocale,
} = Astro.props;

const t = getTranslations(lang);
const siteName = 'Noise Decibel Meter';
const resolvedOgLocale = ogLocale ?? t.ogLocale;
const prefix = lang === 'en' ? '' : `/${lang}`;
const homeHref = prefix ? `${prefix}/` : '/';

const baseUrl = 'https://noisedecibelmeter.com';
const allLocales = ['en', 'es', 'fr', 'ja', 'zh', 'pt'];
const langLabels: Record<string, string> = { en: 'English', es: 'Español', fr: 'Français', ja: '日本語', zh: '中文', pt: 'Português' };
---

<style is:global>
  /* ── Dark mode base ──────────────────────────────────────── */
  html[data-dark] { background: #0a0a0a !important; color: #f2f2f2 !important; }
  html[data-dark] body { background: #0a0a0a !important; }

  /* Nav */
  html[data-dark] .layout-nav { background: rgba(10,10,10,0.85) !important; border-bottom-color: #222 !important; }
  html[data-dark] .nav-brand-text { color: #f2f2f2 !important; }
  html[data-dark] .nav-logo-circle-ring { stroke: #e0e0e0 !important; }
  html[data-dark] .nav-logo-circle-dot { fill: #e0e0e0 !important; }
  html[data-dark] .nav-logo-path { stroke: #e0e0e0 !important; }

  /* Dark toggle button */
  .dark-toggle {
    width: 36px; height: 36px; border-radius: 100px;
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: 1px solid #ebebeb;
    cursor: pointer; transition: border-color 0.2s;
    color: #555;
  }
  .dark-toggle:hover { border-color: #a1a1a1; }
  html[data-dark] .dark-toggle { border-color: #2a2a2a; color: #888; }
  html[data-dark] .dark-toggle:hover { border-color: #555; }

  .icon-moon { display: block; }
  .icon-sun  { display: none; }
  html[data-dark] .icon-moon { display: none; }
  html[data-dark] .icon-sun  { display: block; }

  /* Footer */
  html[data-dark] .layout-footer { background: #111 !important; border-top-color: #222 !important; }
  html[data-dark] .footer-title { color: #f2f2f2 !important; }
  html[data-dark] .footer-tagline { color: #888 !important; }
  html[data-dark] .footer-note { color: #888 !important; }
  html[data-dark] .footer-link { color: #888 !important; }
  html[data-dark] .footer-link:hover { color: #b0b0b0 !important; }
  html[data-dark] .footer-divider { color: #444 !important; }

  /* Lang dropdown */
  .lang-dropdown { position: relative; display: inline-block; }
  .lang-btn {
    display: flex; align-items: center; gap: 4px;
    padding: 0 10px; height: 36px; border-radius: 100px;
    background: transparent; border: 1px solid #ebebeb;
    cursor: pointer; font-size: 12px; font-weight: 500; color: #555;
    transition: border-color 0.2s;
  }
  .lang-btn:hover { border-color: #a1a1a1; }
  html[data-dark] .lang-btn { border-color: #2a2a2a; color: #888; }
  html[data-dark] .lang-btn:hover { border-color: #555; }
  .lang-menu {
    display: none; position: absolute; top: calc(100% + 8px); right: 0;
    background: #fff; border: 1px solid #ebebeb; border-radius: 10px;
    padding: 4px; min-width: 130px; z-index: 100;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  html[data-dark] .lang-menu { background: #111; border-color: #222; box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
  .lang-dropdown.open .lang-menu { display: block; }
  .lang-menu a {
    display: block; padding: 7px 12px; font-size: 13px; color: #444;
    text-decoration: none; border-radius: 7px; transition: background 0.12s;
  }
  .lang-menu a:hover { background: #f5f5f5; }
  html[data-dark] .lang-menu a { color: #ccc; }
  html[data-dark] .lang-menu a:hover { background: #1a1a1a; }
  .lang-menu a.active { font-weight: 600; color: #171717; }
  html[data-dark] .lang-menu a.active { color: #f2f2f2; }

  /* Global body text */
  html[data-dark] main p { color: #b0b0b0 !important; }
  html[data-dark] main li { color: #b0b0b0 !important; }
  html[data-dark] main h2 { color: #e8e8e8 !important; }
  html[data-dark] main a { color: #d0d0d0 !important; }
</style>

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternate links -->
    {allLocales.map(l => (
      <link
        rel="alternate"
        hreflang={l === 'zh' ? 'zh-Hans' : l}
        href={`${baseUrl}${localePath(l, pagePath)}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}${localePath('en', pagePath)}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Noise Decibel Meter — Free Online Sound Level Meter" />
    <meta property="og:locale" content={resolvedOgLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="NoiseDb" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VFVTC4G1G1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VFVTC4G1G1');
    </script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Noise Decibel Meter",
      "url": canonicalUrl,
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": [
        "Real-time decibel measurement",
        "dBA and dBC weighting",
        "60-second history graph",
        "CSV export",
        "No installation required",
        "Works in any modern browser"
      ]
    })} />
  </head>
  <body class="min-h-screen bg-[#fafafa]">

    <!-- Nav -->
    <nav class="layout-nav" style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,0.85);backdrop-filter:blur(12px);border-bottom:1px solid #ebebeb;">
      <div style="max-width:960px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;">
        <a href={homeHref} style="display:flex;align-items:center;gap:8px;text-decoration:none;">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <circle class="nav-logo-circle-ring" cx="10" cy="10" r="8" stroke="#171717" stroke-width="1.5"/>
            <circle class="nav-logo-circle-dot" cx="10" cy="10" r="3" fill="#171717"/>
            <path class="nav-logo-path" d="M10 4v2M10 14v2M4 10h2M14 10h2" stroke="#171717" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="nav-brand-text" style="font-size:14px;font-weight:600;color:#171717;letter-spacing:-0.3px;">Noise Decibel Meter</span>
        </a>
        <div style="display:flex;align-items:center;gap:12px;">
          <span id="nav-live" style="display:none;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11px;color:#888;">
            <span style="width:6px;height:6px;border-radius:50%;background:#50e3c2;display:inline-block;" id="live-dot"></span>
            LIVE
          </span>
          <div class="lang-dropdown" id="langDropdown">
            <button class="lang-btn" onclick="toggleLangMenu()" aria-label="Select language" aria-expanded="false" aria-haspopup="listbox">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              {lang.toUpperCase()}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="lang-menu" role="listbox">
              {allLocales.map(l => (
                <a href={localePath(l, pagePath)} class={l === lang ? 'active' : ''} role="option" aria-selected={l === lang}>
                  {langLabels[l]}
                </a>
              ))}
            </div>
          </div>
          <button class="dark-toggle" onclick="toggleDark()" aria-label="Toggle dark mode">
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer class="layout-footer" style="border-top:1px solid #ebebeb;background:#fff;">
      <div style="max-width:960px;margin:0 auto;padding:28px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span class="footer-title" style="font-size:14px;font-weight:600;color:#171717;">Noise Decibel Meter</span>
          <span class="footer-tagline" style="font-size:14px;color:#888;">— {t.footer.tagline}</span>
        </div>
        <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
          <a href={`${prefix}/about/`} class="footer-link" style="font-size:13px;color:#888;text-decoration:none;transition:color 0.15s;">{t.footer.about}</a>
          <span class="footer-divider" style="color:#ccc;font-size:13px;">·</span>
          <a href={`${prefix}/privacy-policy/`} class="footer-link" style="font-size:13px;color:#888;text-decoration:none;transition:color 0.15s;">{t.footer.privacy}</a>
          <span class="footer-divider" style="color:#ccc;font-size:13px;">·</span>
          <a href={`${prefix}/terms/`} class="footer-link" style="font-size:13px;color:#888;text-decoration:none;transition:color 0.15s;">{t.footer.terms}</a>
          <span class="footer-divider" style="color:#ccc;font-size:13px;">·</span>
          <a href={`${prefix}/contact/`} class="footer-link" style="font-size:13px;color:#888;text-decoration:none;transition:color 0.15s;">{t.footer.contact}</a>
        </div>
      </div>
    </footer>

    <!-- Dark mode init + toggle -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.setAttribute('data-dark', '');
        }
      })();

      function toggleDark() {
        var el = document.documentElement;
        if (el.hasAttribute('data-dark')) {
          el.removeAttribute('data-dark');
          localStorage.setItem('theme', 'light');
        } else {
          el.setAttribute('data-dark', '');
          localStorage.setItem('theme', 'dark');
        }
      }

      function isDark() {
        return document.documentElement.hasAttribute('data-dark');
      }

      function toggleLangMenu() {
        var dd = document.getElementById('langDropdown');
        var btn = dd.querySelector('.lang-btn');
        var isOpen = dd.classList.toggle('open');
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      }

      document.addEventListener('click', function(e) {
        var dd = document.getElementById('langDropdown');
        if (dd && !dd.contains(e.target)) {
          dd.classList.remove('open');
          dd.querySelector('.lang-btn').setAttribute('aria-expanded', 'false');
        }
      });
    </script>

  </body>
</html>
